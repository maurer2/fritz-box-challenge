{
  "name": "fritz-box-challenge",
  "version": "1.0.0",
  "private": true,
  "repository": "git@github.com:maurer2/fritz-box-challenge.git",
  "license": "MIT",
  "author": "Martin",
  "main": "index.js",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dump-box-data": "node --env-file=.env './scripts/dump-box-data.ts'",
    "lint:style": "stylelint 'src/**/*.{css,styles.ts}'",
    "lint:eslint": "eslint '{src,scripts}/**/*.{ts,tsx}'",
    "lint:oxlint": "oxlint src scripts",
    "format": "prettier --write './**/*.{ts,tsx,js,jsx,json}'",
    "start": "vite --mode production",
    "dev": "vite",
    "dev:slow": "VITE_MSW_BEHAVIOUR=SLOW vite",
    "dev:404": "VITE_MSW_BEHAVIOUR=404 vite",
    "dev:network": "VITE_MSW_BEHAVIOUR=NETWORK vite",
    "dev:timeout": "VITE_MSW_BEHAVIOUR=TIMEOUT vite",
    "dev:invalid-html": "VITE_MSW_BEHAVIOUR=INVALID_HTML vite",
    "dev:invalid-fields": "VITE_MSW_BEHAVIOUR=INVALID_FIELDS vite",
    "analyze": "vite build --mode analyze",
    "test:schema": "vitest 'src/schema'",
    "test:types": "tsgo --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-devtools": "^0.10.7",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "modern-normalize": "^3.0.1",
    "msw": "^2.14.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.2",
    "temporal-polyfill": "^1.0.1",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3",
    "zod-compiler": "^1.14.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "^0.8.0",
    "@tanstack/router-generator": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript/native-preview": "7.0.0-dev.20260623.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-styled-components": "^2.3.0",
    "baseline-browser-mapping": "^2.10.38",
    "browserslist": "^4.28.4",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-zod": "4.7.0",
    "jest-styled-components": "^7.4.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "postcss": "^8.5.15",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.1",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-processor-styled-components": "^1.10.0",
    "stylelint-use-nesting": "^6.0.2",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
