{
  "name": "fritz-box-challenge",
  "version": "1.0.0",
  "repository": "git@github.com:maurer2/fritz-box-challenge.git",
  "license": "MIT",
  "author": "Martin",
  "main": "index.js",
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dump-box-data": "node --env-file=.env './scripts/dump-box-data.ts'",
    "lint:style": "stylelint 'src/**/*.{css,styles.ts}'",
    "lint:ts": "eslint '{src,scripts}/**/*.{ts,tsx}'",
    "format": "prettier --write './**/*.{ts,tsx,js,jsx,json}'",
    "start": "vite --mode production",
    "dev": "vite",
    "dev:slow": "VITE_MSW_BEHAVIOUR=SLOW vite",
    "dev:404": "VITE_MSW_BEHAVIOUR=404 vite",
    "dev:network": "VITE_MSW_BEHAVIOUR=NETWORK vite",
    "dev:timeout": "VITE_MSW_BEHAVIOUR=TIMEOUT vite",
    "dev:invalid-html": "VITE_MSW_BEHAVIOUR=INVALID_HTML vite",
    "dev:invalid-fields": "VITE_MSW_BEHAVIOUR=INVALID_FIELDS vite",
    "analyze": "vite build --mode analyze",
    "test:schema": "vitest 'src/schema'",
    "test:types": "tsgo --noEmit"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router": "^1.168.17",
    "@tanstack/react-router-devtools": "^1.166.13",
    "modern-normalize": "^3.0.1",
    "msw": "^2.13.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.4.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6",
    "zod-compiler": "^1.9.1"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/router-generator": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript/native-preview": "7.0.0-dev.20260411.1",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-styled-components": "^2.1.4",
    "baseline-browser-mapping": "^2.10.18",
    "browserslist": "^4.28.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest-styled-components": "^7.4.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.9",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.0",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.0",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-processor-styled-components": "^1.10.0",
    "stylelint-use-nesting": "^6.0.2",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
