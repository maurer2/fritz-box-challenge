{
  "name": "fritz-box-challenge",
  "version": "1.0.0",
  "repository": "git@github.com:maurer2/fritz-box-challenge.git",
  "license": "MIT",
  "author": "Martin",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dump-box-data": "node './scripts/dump-box-data.ts'",
    "lint:style": "stylelint 'src/**/*.{css,styles.ts}'",
    "lint:ts": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write './**/*.{ts,tsx,js,jsx,json}'",
    "start": "VITE_APP_MODE=prod vite",
    "dev": "VITE_APP_MODE=dev vite",
    "test:schema": "vitest './src/schema/boxFields/box.schema.spec.ts'",
    "test:types": "tsgo --noEmit"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router": "^1.168.17",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-generator": "^1.166.28",
    "@tanstack/router-plugin": "^1.167.16",
    "dotenv": "^17.4.1",
    "modern-normalize": "^3.0.1",
    "msw": "^2.13.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.4.0",
    "ts-pattern": "^5.9.0",
    "type-fest": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript/native-preview": "7.0.0-dev.20260411.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-styled-components": "^2.1.4",
    "baseline-browser-mapping": "^2.10.18",
    "browserslist": "^4.28.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest-styled-components": "^7.4.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.9",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.0",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.2",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.0",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-processor-styled-components": "^1.10.0",
    "stylelint-use-nesting": "^6.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "supportedArchitectures": {
      "cpu": [
        "x64",
        "arm64"
      ],
      "os": [
        "darwin",
        "linux",
        "win32"
      ]
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
